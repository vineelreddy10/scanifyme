2026-03-19 21:58:51,383 INFO ipython """Comprehensive RBAC API test for ScanifyMe recovery APIs."""
2026-03-19 21:58:51,384 INFO ipython import frappe
2026-03-19 21:58:51,384 INFO ipython def print_result(label, passed, detail=""):
    status = "✅ PASS" if passed else "❌ FAIL"
    print(f"{status} | {label}")
    if detail:
        print(f"       └─ {detail}")
2026-03-19 21:58:51,384 INFO ipython def test_guest(api_method, args={}, expect_fail=True):
    """Test API as Guest - should fail for non-public APIs."""
    frappe.set_user("Guest")
    try:
        result = frappe.call(api_method, **args)
        if expect_fail:
            return False, f"Expected permission error but got: {type(result)}"
        return True, str(result)[:100]
    except Exception as e:
        err_msg = str(e)
        if "Permission" in err_msg or "permission" in err_msg or "Login" in err_msg or "not permitted" in err_msg.lower():
            return True, "Permission denied (expected)"
        return False, f"Unexpected error: {err_msg[:100]}"
    finally:
        frappe.set_user("Administrator")
2026-03-19 21:58:51,384 INFO ipython def test_owner(api_method, args={}, expect_success=True):
    """Test API as demo owner - should succeed for own data."""
    frappe.set_user("demo@scanifyme.app")
    try:
        result = frappe.call(api_method, **args)
        if expect_success:
            return True, "Success"
        return False, f"Expected fail but got: {str(result)[:100]}"
    except Exception as e:
        return False, str(e)[:100]
    finally:
        frappe.set_user("Administrator")
2026-03-19 21:58:51,384 INFO ipython def test_admin(api_method, args={}, expect_success=True):
    """Test API as Administrator - should succeed for all."""
    frappe.set_user("Administrator")
    try:
        result = frappe.call(api_method, **args)
        if expect_success:
            return True, "Success"
        return False, f"Expected fail but got: {str(result)[:100]}"
    except Exception as e:
        return False, str(e)[:100]
    finally:
        frappe.set_user("Administrator")
2026-03-19 21:58:51,384 INFO ipython def get_demo_case_id():
    """Get a valid demo recovery case ID."""
    cases = frappe.get_all("Recovery Case", fields=["name"], limit=1)
    return cases[0]["name"] if cases else None
2026-03-19 21:58:51,384 INFO ipython def get_wrong_owner_case_id():
    """Get a case that does NOT belong to demo owner."""
    demo_op = frappe.db.get_value("Owner Profile", {"user": "demo@scanifyme.app"}, "name")
    cases = frappe.get_all("Recovery Case", filters={"owner_profile": ["!=", demo_op]}, fields=["name"], limit=1)
    return cases[0]["name"] if cases else None
