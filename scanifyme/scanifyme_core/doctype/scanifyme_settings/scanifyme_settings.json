{
  "name": "ScanifyMe Settings",
  "doctype": "DocType",
  "module": "ScanifyMe Core",
  "autoname": "field:site_name",
  "is_submittable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "site_name",
      "fieldtype": "Data",
      "label": "Site Name",
      "reqd": 1,
      "unique": 0,
      "description": "Name of the ScanifyMe site"
    },
    {
      "fieldname": "default_privacy_level",
      "fieldtype": "Select",
      "label": "Default Privacy Level",
      "options": "High\nMedium\nLow",
      "default": "High",
      "description": "Default privacy level for new items"
    },
    {
      "fieldname": "allow_anonymous_messages",
      "fieldtype": "Check",
      "label": "Allow Anonymous Messages",
      "default": "1",
      "description": "Allow finders to send messages without registration"
    },
    {
      "fieldname": "allow_location_sharing",
      "fieldtype": "Check",
      "label": "Allow Location Sharing",
      "default": "1",
      "description": "Allow finders to share their location with owners"
    },
    {
      "fieldname": "default_reward_message",
      "fieldtype": "Text Editor",
      "label": "Default Reward Message",
      "description": "Default message shown to finders about rewards"
    },
    {
      "fieldname": "max_messages_per_hour",
      "fieldtype": "Int",
      "label": "Max Messages Per Hour",
      "default": "10",
      "description": "Maximum number of messages a finder can send per hour"
    },
    {
      "fieldname": "max_scans_per_minute",
      "fieldtype": "Int",
      "label": "Max Scans Per Minute",
      "default": "5",
      "description": "Maximum number of scans allowed per minute to prevent abuse"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 0,
      "cancel": 0,
      "amend": 0
    },
    {
      "role": "ScanifyMe Admin",
      "read": 1,
      "write": 1,
      "create": 0,
      "delete": 0,
      "submit": 0,
      "cancel": 0,
      "amend": 0
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "site_name",
  "show_name_in_global_search": 1,
  "allow_copy": 0,
  "allow_rename": 0,
  "allow_import": 0,
  "allow_events_for": "",
  "is_negative": 0,
  "image_field": "",
  "timeline_field": "",
  "title_format": "",
  "push_notification_title": "",
  "sort_links": {},
  "workflow_docs": [],
  "hide_toolbar": 0,
  "track_seen": 0,
  "custom": 0,
  "has_web_view": 0,
  "show_sidebar": 0,
  "documentation_web_pages": {},
  "naming_rule": "Manual",
  "description": "Global settings for ScanifyMe application"
}
