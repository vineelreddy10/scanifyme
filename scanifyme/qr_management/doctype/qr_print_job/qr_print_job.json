{
  "name": "QR Print Job",
  "module": "QR Management",
  "doctype": "DocType",
  "engine": "InnoDB",
  "field_order": [
    "naming_series",
    "print_job_name",
    "qr_batch",
    "status",
    "template_name",
    "column_break_5",
    "output_file",
    "item_count",
    "generated_on",
    "printed_on",
    "column_break_10",
    "created_by",
    "notes"
  ],
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Series",
      "options": "PRINT-.YYYY.-",
      "default": "PRINT-.YYYY.-",
      "hidden": 1
    },
    {
      "fieldname": "print_job_name",
      "fieldtype": "Data",
      "label": "Print Job Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "qr_batch",
      "fieldtype": "Link",
      "label": "QR Batch",
      "options": "QR Batch",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "\nDraft\nGenerated\nReady to Print\nPrinted\nCancelled",
      "default": "Draft",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "template_name",
      "fieldtype": "Data",
      "label": "Template Name",
      "description": "Optional template for printing (e.g., label_size, layout)",
      "in_list_view": 0
    },
    {
      "fieldname": "column_break_5",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "output_file",
      "fieldtype": "Attach",
      "label": "Output File",
      "description": "Generated print output file (PDF/HTML)",
      "in_list_view": 0
    },
    {
      "fieldname": "item_count",
      "fieldtype": "Int",
      "label": "Item Count",
      "default": "0",
      "in_list_view": 1
    },
    {
      "fieldname": "generated_on",
      "fieldtype": "Datetime",
      "label": "Generated On",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "printed_on",
      "fieldtype": "Datetime",
      "label": "Printed On",
      "read_only": 1,
      "in_list_view": 0
    },
    {
      "fieldname": "column_break_10",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "created_by",
      "fieldtype": "Link",
      "label": "Created By",
      "options": "User",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes",
      "in_list_view": 0
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "ScanifyMe Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "ScanifyMe Operations",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ],
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "print_job_name"
}
