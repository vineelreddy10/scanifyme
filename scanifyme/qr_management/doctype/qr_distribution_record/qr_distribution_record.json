{
  "name": "QR Distribution Record",
  "module": "QR Management",
  "doctype": "DocType",
  "engine": "InnoDB",
  "field_order": [
    "naming_series",
    "distribution_name",
    "qr_batch",
    "status",
    "distributed_to_type",
    "column_break_5",
    "distributed_to_name",
    "distributed_on",
    "quantity",
    "column_break_10",
    "created_by",
    "notes"
  ],
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Series",
      "options": "DIST-.YYYY.-",
      "default": "DIST-.YYYY.-",
      "hidden": 1
    },
    {
      "fieldname": "distribution_name",
      "fieldtype": "Data",
      "label": "Distribution Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "qr_batch",
      "fieldtype": "Link",
      "label": "QR Batch",
      "options": "QR Batch",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "\nDraft\nPacked\nDispatched\nDelivered\nCancelled",
      "default": "Draft",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "distributed_to_type",
      "fieldtype": "Select",
      "label": "Distributed To Type",
      "options": "\nCustomer\nReseller\nInternal Stock\nDemo\nTest",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "column_break_5",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "distributed_to_name",
      "fieldtype": "Data",
      "label": "Distributed To Name",
      "description": "Name of customer, reseller, or destination",
      "in_list_view": 1
    },
    {
      "fieldname": "distributed_on",
      "fieldtype": "Datetime",
      "label": "Distributed On",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "quantity",
      "fieldtype": "Int",
      "label": "Quantity",
      "default": "0",
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_10",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "created_by",
      "fieldtype": "Link",
      "label": "Created By",
      "options": "User",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes",
      "in_list_view": 0
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "ScanifyMe Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "ScanifyMe Operations",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ],
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "distribution_name"
}
