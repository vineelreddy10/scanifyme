import frappe
frappe.init('test.localhost')
frappe.connect()

# Create second owner user
user_email = 'owner2@scanifyme.app'
if not frappe.db.exists('User', user_email):
    user = frappe.get_doc({
        'doctype': 'User',
        'email': user_email,
        'first_name': 'Owner',
        'last_name': 'Two',
        'send_welcome_email': 0,
        'user_type': 'Website User',
        'enabled': 1,
    })
    user.insert(ignore_permissions=True)
    frappe.db.commit()
    print(f'Created user: {user_email}')

# Create owner profile for second user
if not frappe.db.exists('Owner Profile', {'user': user_email}):
    profile = frappe.get_doc({
        'doctype': 'Owner Profile',
        'user': user_email,
        'display_name': 'Owner Two',
        'phone': '+1987654321',
        'address': '456 Test Street, Test City, TC 67890',
        'is_verified': 1,
    })
    profile.insert(ignore_permissions=True)
    frappe.db.commit()
    print(f'Created owner profile: {profile.name}')

print('Second owner user created for permission testing')

