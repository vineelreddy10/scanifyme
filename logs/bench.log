from scanifyme.onboarding.services.onboarding_service import compute_onboarding_state, persist_onboarding_state, compute_owner_next_actions
from scanifyme.utils.permissions import has_admin_role

# Test 1: Admin gets full state (no recursion)
print('=== Test 1: compute_onboarding_state(Administrator) ===')
result = compute_onboarding_state('Administrator')
print(f'completion_percent: {result["completion_percent"]}')
print(f'onboarding_completed: {result["onboarding_completed"]}')

# Test 2: Admin gets empty next actions (no recursion)
print()
print('=== Test 2: compute_owner_next_actions(Administrator) ===')
actions = compute_owner_next_actions('Administrator')
print(f'Actions count: {len(actions)}')

# Test 3: persist creates doc (no recursion)
print()
print('=== Test 3: persist_onboarding_state (test owner) ===')
result = persist_onboarding_state('NonExistentOwner@nonexistent.app')
print(f'success: {result["success"]}')
print(f'message: {result["message"]}')

# Test 4: has_admin_role
print()
print('=== Test 4: has_admin_role(Administrator) ===')
print(f'Result: {has_admin_role("Administrator")}')

print()
print('=== ALL TESTS PASSED (no RecursionError) ===')

